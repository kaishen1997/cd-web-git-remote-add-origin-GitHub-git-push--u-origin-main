# Database connection string (PostgreSQL)
# For Vercel, use a Postgres database (e.g., Vercel Postgres, Supabase, Neon)
# Prisma supports PostgreSQL, MySQL, SQLite, SQL Server, MongoDB and CockroachDB.
# See the documentation for all the connection string options: https://pris.ly/d/connection-strings
DATABASE_URL="postgresql://user:password@host:port/dbname?schema=public"

# Resend API Key for sending inquiry notifications
# Get your key at https://resend.com
RESEND_API_KEY="re_..."

# Email address to receive inquiry notifications
ADMIN_EMAIL="sales@tqweighing.com"

# Google Analytics Measurement ID (optional)
# Get your ID from Google Analytics 4 (GA4) property
NEXT_PUBLIC_GA_ID="G-XXXXXXXXXX"
