generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Product {
  id          String    @id @default(cuid())
  name        String
  slug        String    @unique
  description String?
  category    String?
  images      String[]
  variants    Variant[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Variant {
  id              String         @id @default(cuid())
  productId       String
  product         Product        @relation(fields: [productId], references: [id])
  
  // Core attributes
  weightValue     Float
  weightUnit      String         // mg, g, kg
  oimlClass       OimlClass
  material        String         // e.g., Stainless Steel, Cast Iron
  shape           String?        // e.g., Cylindrical, Rectangular
  
  sku             String?        @unique
  
  // Technical Specifications (specific to this variant)
  spec            TechnicalSpec?
  inquiryItems    InquiryItem[]
  
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@unique([productId, weightValue, weightUnit, oimlClass, material])
}

model TechnicalSpec {
  id               String   @id @default(cuid())
  variantId        String   @unique
  variant          Variant  @relation(fields: [variantId], references: [id])
  
  maxPermissibleError Float?   // in mg
  magnetization       Float?   // in µT
  susceptibility      Float?   // χ
  density             Float?   // kg/m³
  surfaceRoughness    Float?   // Ra (µm)
  
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

enum OimlClass {
  E1
  E2
  F1
  F2
  M1
  M2
  M3
}

model Inquiry {
  id          String        @id @default(cuid())
  name        String
  email       String
  company     String?
  message     String?
  items       InquiryItem[]
  status      InquiryStatus @default(PENDING)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}

model InquiryItem {
  id        String  @id @default(cuid())
  inquiryId String
  inquiry   Inquiry @relation(fields: [inquiryId], references: [id])
  variantId String
  variant   Variant @relation(fields: [variantId], references: [id])
  quantity  Int
}

enum InquiryStatus {
  PENDING
  REVIEWED
  REPLIED
  CLOSED
}
